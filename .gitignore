# Rust / Cargo
target/
**/*.rs.bk

# Node.js (root-level lockfiles if any)
node_modules/

# OS
.DS_Store
Thumbs.db
Desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Claude Code
.claude/*.lock

# Superpowers skills (local tooling, not part of the project)
docs/superpowers/

# Environment / secrets
.env
.env.*
!.env.example

# Tauri signing keys
.tauri-privkey
.tauri-privkey.pub
.tauri-pubkey

# Speedwave runtime data (should never be committed)
.speedwave/

# Worktree metadata
.worktree.json

# Coverage
coverage/
*.lcov
*.profraw

# Swift Package Manager
.build/
.swiftpm/

# Build artifacts
*.dmg
*.exe
*.msi
*.deb

# Bundled Lima binaries (downloaded by `make download-lima`)
desktop/src-tauri/lima/
desktop/src-tauri/THIRD-PARTY-LICENSES/

# Bundled Node.js binary (downloaded by `make download-nodejs`)
desktop/src-tauri/nodejs/

# Bundled nerdctl-full (downloaded by `make download-nerdctl-full`, Linux .deb only)
desktop/src-tauri/nerdctl-full/

# Bundled WSL2 resources (downloaded by `make download-wsl-resources`, Windows only)
desktop/src-tauri/wsl/

# Bundled macOS native CLI helpers (compiled by `make build-native-macos`)
desktop/src-tauri/calendar-cli
desktop/src-tauri/mail-cli
desktop/src-tauri/notes-cli
desktop/src-tauri/reminders-cli

# Bundled container build context and mcp-os (copied before Tauri build)
desktop/src-tauri/build-context/
desktop/src-tauri/mcp-os/
.e2e-artifacts/
