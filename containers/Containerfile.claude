# OCI Containerfile for Speedwave Claude container
# Base: node:24-bookworm-slim (Debian)
# Multi-arch: linux/amd64 + linux/arm64 (Apple Silicon)
FROM node:24-bookworm-slim

# Security: container user is set per-platform via compose `user:` field.
# macOS/Windows: "1000:1000" (unprivileged, containerd runs as root).
# Linux rootless nerdctl: "0:0" (root in user namespace = host user UID;
# UID 1000 maps to subuid ~101000, breaking bind-mount access).
# The base image has uid/gid 1000 ("node"). Rootless BuildKit cannot modify
# /etc/passwd or /etc/group (overlayfs restrictions). We skip user renaming:
# the container only needs a writable home at /home/speedwave.
# See also: crates/speedwave-runtime/src/consts.rs (CONTAINER_USER_UNPRIVILEGED,
# CONTAINER_USER_ROOTLESS) and compose.template.yml (user: "${CONTAINER_USER}").
ENV HOME=/home/speedwave
RUN mkdir -p /home/speedwave && chown 1000:1000 /home/speedwave

# Apt resilience: retries for update (network), unsafe-io for install (nested virt I/O).
# --force-unsafe-io skips fsync during dpkg unpack — safe in a container build context
# (layers are disposable) and eliminates the fsync bottleneck in nested virtualization
# environments (WSL2/Hyper-V inside VMware). Installed files are byte-identical.
RUN apt-get update -o Acquire::Retries=3 && \
    apt-get install -y --no-install-recommends \
        -o Dpkg::Options::="--force-unsafe-io" \
        bash \
        ca-certificates \
        curl \
        git \
        wget \
    && rm -rf /var/lib/apt/lists/*

# Create directories for resources (read-only mount point)
RUN mkdir -p /speedwave/resources && \
    chown -R 1000:1000 /speedwave

# Create workspace directory (read-only mount point for project)
RUN mkdir -p /workspace && \
    chown 1000:1000 /workspace

# Install Claude Code as speedwave user, then copy binary to image layer.
# `claude install` puts the binary at ~/.local/bin/claude (~210MB) and
# ~/.local/share/claude/versions/. At runtime /home/speedwave is a VirtioFS
# volume mount — reading 210MB through VirtioFS causes a ~10s freeze (Apple
# Virtualization hypervisor spike). Fix: install as speedwave, then copy the
# resolved binary to /usr/local/bin which lives on the VM's ext4 disk.

# Copy reusable installer (DRY — also used by entrypoint.sh at runtime)
COPY --chmod=755 install-claude.sh /usr/local/bin/install-claude.sh

# Required — no default intentional (fail-closed; must be passed via --build-arg)
ARG CLAUDE_VERSION
USER 1000
# The official installer downloads the binary from GCS and verifies its SHA256
# against a version-pinned manifest.json. See install-claude.sh for details.
RUN /usr/local/bin/install-claude.sh "${CLAUDE_VERSION}"
USER root
RUN CLAUDE_BIN=$(readlink -f /home/speedwave/.local/bin/claude) && \
    cp "$CLAUDE_BIN" /usr/local/bin/claude && \
    chmod +x /usr/local/bin/claude && \
    rm -rf /home/speedwave/.local/share/claude && \
    rm -f /home/speedwave/.local/bin/claude && \
    ln -sf /usr/local/bin/claude /home/speedwave/.local/bin/claude

# Copy entrypoint late to avoid busting the ~210MB Claude Code layer cache
COPY --chmod=755 entrypoint.sh /usr/local/bin/entrypoint.sh

# Final: run as unprivileged user
USER 1000
WORKDIR /home/speedwave

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
