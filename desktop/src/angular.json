{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "speedwave-desktop-ui": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "polyfills": [],
            "styles": ["src/styles.css"],
            "scripts": [],
            "assets": [
              {
                "glob": "**/*",
                "input": "public",
                "output": "/"
              }
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                }
              ],
              "outputHashing": "all",
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true,
                  "inlineCritical": false
                },
                "fonts": false
              }
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "buildTarget": "speedwave-desktop-ui:build:development",
            "tsConfig": "tsconfig.spec.json"
          }
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "port": 4270
          },
          "configurations": {
            "production": {
              "buildTarget": "speedwave-desktop-ui:build:production"
            },
            "development": {
              "buildTarget": "speedwave-desktop-ui:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
