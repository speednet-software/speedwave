{
  "bundle": {
    "createUpdaterArtifacts": false,
    "resources": {
      "nerdctl-full/bin/": "nerdctl-full/bin/",
      "nerdctl-full/lib/": "nerdctl-full/lib/",
      "nerdctl-full/libexec/": "nerdctl-full/libexec/",
      "nerdctl-full/share/": "nerdctl-full/share/",
      "THIRD-PARTY-LICENSES/": "THIRD-PARTY-LICENSES/",
      "build-context/containers/": "build-context/containers/",
      "build-context/mcp-servers/": "build-context/mcp-servers/",
      "nodejs/bin/node": "nodejs/bin/node",
      "mcp-os/": "mcp-os/",
      "cli/speedwave": "cli/speedwave"
    },
    "linux": {
      "deb": {
        "depends": ["uidmap", "dbus-user-session"],
        "section": "utils",
        "priority": "optional",
        "files": {
          "/etc/apparmor.d/speedwave.rootlesskit": "packaging/linux/apparmor-rootlesskit.profile"
        }
      }
    }
  }
}
