# Speedwave MCP Hub - Orchestrator
# Routes requests to isolated MCP workers via HTTP bridge
#
# Security:
# - NO tokens - hub only orchestrates
# - NO direct API access - all via HTTP bridge to workers
# - Blast radius: compromise of hub exposes NO service credentials

# Build stage
FROM node:24-alpine AS builder

WORKDIR /build

# ─────────────────────────────────────────────────────────────────────────────
# Stage 1: Build shared library first (dependency)
# ─────────────────────────────────────────────────────────────────────────────
COPY tsconfig.base.json ./
COPY shared/package*.json ./shared/
RUN --mount=type=cache,target=/root/.npm cd shared && npm install

COPY shared/src ./shared/src
COPY shared/tsconfig.json ./shared/
RUN cd shared && npm run build

# ─────────────────────────────────────────────────────────────────────────────
# Stage 2: Build hub (imports from ../shared/dist)
# ─────────────────────────────────────────────────────────────────────────────
COPY hub/package*.json ./hub/
RUN --mount=type=cache,target=/root/.npm cd hub && npm install

COPY hub/src ./hub/src
COPY hub/tsconfig.json ./hub/
RUN cd hub && npm run build

# Prune devDependencies
RUN cd hub && npm prune --omit=dev

# Production stage
FROM node:24-alpine

# curl for healthcheck
RUN apk add --no-cache curl

WORKDIR /app

# Copy built shared library (required at runtime for relative imports)
COPY --from=builder /build/shared/dist ../shared/dist
COPY --from=builder /build/shared/package.json ../shared/
COPY --from=builder /build/shared/node_modules ../shared/node_modules

# Copy built hub application
COPY --from=builder /build/hub/package*.json ./
COPY --from=builder /build/hub/dist ./dist
COPY --from=builder /build/hub/node_modules ./node_modules

# Create directories
RUN mkdir -p /context && chown -R node:node /context /app /app/../shared

# Security: non-root user
USER node

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD curl -sf http://localhost:3000/health || exit 1

EXPOSE 3000

ENV PORT=3000 \
    NODE_ENV=production

CMD ["node", "dist/index.js"]
