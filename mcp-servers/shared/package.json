    "eslint": "^9.16.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.8.0",
    "eslint-plugin-prettier": "^5.1.0",
    "globals": "^17.3.0",
    "prettier": "^3.2.0",
