# Speedwave E2E — SSH targets for remote test machines.
# Copy to .env and fill in your values. .env is gitignored.

# Format: user@host (IP or hostname)
SPEEDWAVE_LINUX_HOST=user@100.x.x.x
SPEEDWAVE_WINDOWS_HOST=user@100.x.x.x
SPEEDWAVE_MACOS_HOST=user@100.x.x.x

# Optional: non-default SSH port for Windows (default: 22)
# SPEEDWAVE_WINDOWS_SSH_PORT=22

# Optional: WSL2 distro name on the Windows machine (default: Ubuntu-22.04)
# SPEEDWAVE_WINDOWS_WSL_DISTRO=Ubuntu-22.04
